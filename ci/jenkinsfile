pipeline {
    agent {
        label 'helm3'
    }
    options {
        buildDiscarder logRotator(artifactDaysToKeepStr: '', artifactNumToKeepStr: '', daysToKeepStr: '', numToKeepStr: '5')
    }
    stages {
        stage('Checkout Code') {
            steps {
                checkout scmGit(
                    branches: [[name: "${env.BRANCH_NAME}"]], extensions: [], userRemoteConfigs: [[url: 'https://github.com/Yogeshwaran-Palanisamy/jenkins/']]
                    )
            }
        }
        stage('Render Helm Charts') {
            steps {
                container('helm') {
                    script {
                        deployHelm()
                    }
                }
            }
        }
        stage('Deploy to Kubernetes') {
            when {
              anyOf {
                branch 'main'
                branch 'features/yogesh/**'
              }
            }
            steps {
                container('helm') {
                    deployHelm(true)
                }
            }
        }
    }
}
